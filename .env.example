# Database
DATABASE_URL="file:./ollama-admin.db"
# DATABASE_URL="postgresql://user:pass@host:5432/ollamaadmin"

# App
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Auth (admin user is created during first-time setup wizard)
# AUTH_DISABLED=true  # Set to true only for local development to bypass login

# Ollama (default server, also configurable from the UI)
DEFAULT_OLLAMA_URL="http://localhost:11434"

# Logging
LOG_RETENTION_DAYS=90
LOG_STORE_PROMPTS=true

# Catalog
CATALOG_REFRESH_ENABLED=true
CATALOG_RATE_LIMIT_MS=2000

# HTTP Proxy (for servers behind a corporate proxy that need to reach ollama.com)
# HTTPS_PROXY=http://proxy.example.com:8080

# GPU Agent (optional)
GPU_AGENT_ENABLED=false
