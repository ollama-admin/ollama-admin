echo "Running pre-push checks..."

# Version bump check: ensure version differs from main
CURRENT_VERSION=$(node -p "require('./package.json').version")
MAIN_VERSION=$(git show main:package.json 2>/dev/null | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{console.log(JSON.parse(d).version)})" 2>/dev/null)

if [ -n "$MAIN_VERSION" ] && [ "$CURRENT_VERSION" = "$MAIN_VERSION" ]; then
  echo ""
  echo "ERROR: Version in package.json ($CURRENT_VERSION) has not been bumped."
  echo "Run one of:"
  echo "  npm version patch --no-git-tag-version"
  echo "  npm version minor --no-git-tag-version"
  echo "  npm version major --no-git-tag-version"
  echo ""
  exit 1
fi

echo "Version: $MAIN_VERSION -> $CURRENT_VERSION"

# i18n completeness check
echo "Checking i18n translations..."
node -e "
const fs = require('fs');
const path = require('path');
const dir = path.join(process.cwd(), 'messages');
const locales = fs.readdirSync(dir).filter(f => f.endsWith('.json')).map(f => f.replace('.json',''));
const ref = JSON.parse(fs.readFileSync(path.join(dir, 'en.json'), 'utf8'));

function getKeys(obj, prefix = '') {
  return Object.entries(obj).flatMap(([k, v]) =>
    typeof v === 'object' && v !== null
      ? getKeys(v, prefix ? prefix + '.' + k : k)
      : [prefix ? prefix + '.' + k : k]
  );
}

const refKeys = new Set(getKeys(ref));
let missing = false;

for (const locale of locales) {
  if (locale === 'en') continue;
  const data = JSON.parse(fs.readFileSync(path.join(dir, locale + '.json'), 'utf8'));
  const localeKeys = new Set(getKeys(data));
  const absent = [...refKeys].filter(k => !localeKeys.has(k));
  if (absent.length > 0) {
    console.error('Missing keys in ' + locale + '.json (' + absent.length + '):');
    absent.forEach(k => console.error('  - ' + k));
    missing = true;
  }
}

if (missing) process.exit(1);
console.log('All locales complete.');
" || exit 1

# Full lint
echo "Running lint..."
npx eslint . || exit 1

# Ruff check (Python)
if command -v ruff &> /dev/null; then
  echo "Running ruff..."
  ruff check gpu-agent/ || exit 1
fi

# Unit tests
echo "Running tests..."
npx vitest run || exit 1

# Production build
echo "Running build..."
npm run build || exit 1

echo "All pre-push checks passed!"
